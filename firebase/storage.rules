rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Feedback screenshots: each authenticated user can write under their own
    // uid path; any authenticated user (incl. admins, eventually) can read.
    // Max 5 MB per upload; image content types only.
    match /feedback_screenshots/{userId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
